# ─────────────────────────────────────────────────────────────────────────────
# MakaanBook — Environment Variables
# Copy this file to `.env` and fill in your actual values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase Settings (server-side, used by supabase-js on SSR) ──────────────
SUPABASE_PROJECT_ID="your-supabase-project-id"
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# CAUTION: The service role key bypasses RLS. Only use it on the server side.
# Never expose this key in client-side code or public repos.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ── Vite Client-Side Supabase vars (must be prefixed VITE_) ──────────────────
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# ── Google Gemini API (for AI Hinglish assistant) ────────────────────────────
# Obtain your key from https://aistudio.google.com/app/apikey
# Model used: gemini-1.5-flash-latest
GEMINI_API_KEY="your-google-gemini-api-key"

# ── Optional: Deployment / Public Site URL ───────────────────────────────────
# Used for og:url and canonical meta tags in production
# VITE_PUBLIC_URL="https://your-app.vercel.app"
